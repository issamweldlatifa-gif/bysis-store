# ============================================================
# Bysis Backend — Environment Variables
# Copy this file to ".env" and fill in real values.
# ============================================================

# Port the API server listens on
PORT=3001

# JWT secret used to sign auth tokens (CHANGE THIS in production!)
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_secret_string

# Token expiry
JWT_EXPIRES_IN=7d

# Comma-separated list of allowed origins for CORS.
# In production: https://yourdomain.com
CORS_ORIGIN=http://localhost:8000,http://localhost:5173,http://127.0.0.1:8000

# Database file location (SQLite). Use a hosted Postgres URL in production.
DB_PATH=./data/bysis.db
